@page "/ingredients"
@inject IIngredientService IngredientService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="page-title">
    <div>
        <h2>🥕 Ingrédients</h2>
        <p class="page-subtitle">Gérer la liste des ingrédients utilisés dans les recettes.</p>
    </div>

    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/ingredients/create")'>
        + Ajouter un ingrédient
    </button>
</div>

<div class="search-bar">
    <input class="form-control"
           placeholder="Rechercher un ingrédient par nom..."
           @bind="searchTerm"
           @bind:event="oninput"
           @onkeyup="OnSearch" />
</div>

@if (ingredients == null)
{
    <div class="empty-state">
        Chargement des ingrédients...
    </div>
}
else if (!ingredients.Any())
{
    <div class="empty-state">
        Aucun ingrédient trouvé.
    </div>
}
else
{
    <div class="table-card">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Calories / Unité</th>
                    <th>Unité</th>
                    <th>Description</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ingredient in ingredients)
                {
                    <tr>
                        <td>
                            <strong>@ingredient.Name</strong>
                        </td>
                        <td>@ingredient.CaloriesPerUnit kcal</td>
                        <td>@ingredient.Unit</td>
                        <td>@ingredient.Description</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-warning me-1"
                                    @onclick='() => Nav.NavigateTo($"/ingredients/edit/{ingredient.Id}")'>
                                ✏️ Modifier
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    @onclick="() => DeleteAsync(ingredient.Id)">
                                🗑️ Supprimer
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Ingredient>? ingredients;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        ingredients = await IngredientService.GetAllAsync();
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            await LoadAsync();
        else
            ingredients = await IngredientService.SearchAsync(searchTerm);
    }

    private async Task DeleteAsync(int id)
    {
        await IngredientService.DeleteAsync(id);
        await LoadAsync();
    }
}