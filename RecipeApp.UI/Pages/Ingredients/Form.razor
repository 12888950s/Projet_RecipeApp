@page "/ingredients/create"
@page "/ingredients/edit/{Id:int}"
@inject IIngredientService IngredientService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="page-title">
    <div>
        <h2>@(Id == null ? "➕ Nouvel ingrédient" : "✏️ Modifier l'ingrédient")</h2>
        <p class="page-subtitle">
            @(Id == null ? "Ajouter un nouvel ingrédient à la base." : "Modifier les informations de cet ingrédient.")
        </p>
    </div>
</div>

<div class="form-card">
    <EditForm Model="model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Nom</label>
                <InputText class="form-control"
                           placeholder="Ex: Tomate, Riz, Poulet..."
                           @bind-Value="model.Name" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Calories par unité</label>
                <InputNumber class="form-control"
                             placeholder="Ex: 120"
                             @bind-Value="model.CaloriesPerUnit" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Unité</label>
            <InputText class="form-control"
                       placeholder="Ex: 100g, pièce, ml..."
                       @bind-Value="model.Unit" />
        </div>

        <div class="mb-4">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control"
                           placeholder="Ajouter une courte description..."
                           @bind-Value="model.Description"
                           rows="4" />
        </div>

        <div class="d-flex justify-content-end gap-2">
            <button class="btn btn-secondary" type="button"
                    @onclick='() => Nav.NavigateTo("/ingredients")'>
                Annuler
            </button>

            <button class="btn btn-primary" type="submit">
                💾 Enregistrer
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private Ingredient model = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Id != null)
        {
            var existing = await IngredientService.GetByIdAsync(Id.Value);
            if (existing != null)
                model = existing;
        }
    }

    private async Task SaveAsync()
    {
        if (Id == null)
            await IngredientService.CreateAsync(model);
        else
            await IngredientService.UpdateAsync(Id.Value, model);

        Nav.NavigateTo("/ingredients");
    }
}