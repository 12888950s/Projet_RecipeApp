@page "/"
@inject IAnalyticsService AnalyticsService
@rendermode InteractiveServer

<div class="page-title">
    <div>
        <h2>📊 Dashboard</h2>
        <p class="page-subtitle">
            Vue globale des recettes, catégories, cuisines et statistiques nutritionnelles.
        </p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card stat-primary">
            <div class="stat-icon">🍽️</div>
            <div>
                <p class="stat-label">Total Recettes</p>
                <h3>@totalRecipes</h3>
                <span class="stat-note">recettes enregistrées</span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card stat-warning">
            <div class="stat-icon">🔥</div>
            <div>
                <p class="stat-label">Calories Moyennes</p>
                <h3>@globalAvgCalories.ToString("F0")</h3>
                <span class="stat-note">kcal par recette</span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card stat-danger">
            <div class="stat-icon">🏷️</div>
            <div>
                <p class="stat-label">Catégories</p>
                <h3>@categoryCount</h3>
                <span class="stat-note">types de repas</span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card stat-success">
            <div class="stat-icon">🌍</div>
            <div>
                <p class="stat-label">Types de Cuisine</p>
                <h3>@cuisineCount</h3>
                <span class="stat-note">cuisines différentes</span>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="empty-state">
        Chargement des statistiques...
    </div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card chart-card">
                <div class="card-header">
                    🍽️ Recettes par Catégorie
                </div>
                <div class="card-body">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card chart-card">
                <div class="card-header">
                    🌍 Recettes par Type de Cuisine
                </div>
                <div class="card-body">
                    <canvas id="cuisineChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card chart-card">
                <div class="card-header">
                    🔥 Top 5 Recettes Caloriques
                </div>
                <div class="card-body">
                    <canvas id="topCaloriesChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card chart-card">
                <div class="card-header">
                    📈 Calories Moyennes par Catégorie
                </div>
                <div class="card-body">
                    <canvas id="avgCaloriesChart"></canvas>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool chartsRendered = false;

    private int totalRecipes;
    private float globalAvgCalories;
    private int categoryCount;
    private int cuisineCount;

    private Dictionary<string, int> categoryData = new();
    private Dictionary<string, int> cuisineData = new();
    private List<(string Title, float Calories)> topCaloric = new();
    private Dictionary<string, float> avgCaloriesByCategory = new();

    protected override async Task OnInitializedAsync()
    {
        var byCat = await AnalyticsService.GetRecipeCountByCategoryAsync();
        var byCuisine = await AnalyticsService.GetRecipeCountByCuisineAsync();
        var avgByCat = await AnalyticsService.GetAvgCaloriesByCategoryAsync();

        topCaloric = await AnalyticsService.GetTopCaloricRecipesAsync(5);
        globalAvgCalories = await AnalyticsService.GetGlobalAverageCaloriesAsync();

        categoryData = byCat.ToDictionary(k => k.Key.ToString(), v => v.Value);
        cuisineData = byCuisine.ToDictionary(k => k.Key.ToString(), v => v.Value);
        avgCaloriesByCategory = avgByCat.ToDictionary(k => k.Key.ToString(), v => v.Value);

        totalRecipes = categoryData.Values.Sum();
        categoryCount = categoryData.Count;
        cuisineCount = cuisineData.Count;

        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !chartsRendered)
        {
            chartsRendered = true;
            await RenderCharts();
        }
    }

    private async Task RenderCharts()
    {
        var catLabels = categoryData.Keys.ToArray();
        var catValues = categoryData.Values.ToArray();

        var cuisineLabels = cuisineData.Keys.ToArray();
        var cuisineValues = cuisineData.Values.ToArray();

        var topLabels = topCaloric.Select(t => t.Title).ToArray();
        var topValues = topCaloric.Select(t => t.Calories).ToArray();

        var avgLabels = avgCaloriesByCategory.Keys.ToArray();
        var avgValues = avgCaloriesByCategory.Values.ToArray();

        await JS.InvokeVoidAsync("renderCharts",
            catLabels, catValues,
            cuisineLabels, cuisineValues,
            topLabels, topValues,
            avgLabels, avgValues);
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
}