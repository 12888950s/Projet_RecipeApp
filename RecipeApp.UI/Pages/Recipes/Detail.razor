@page "/recipes/{Id:int}"
@inject IRecipeService RecipeService
@inject NavigationManager Nav
@rendermode InteractiveServer

@if (recipe == null)
{
    <div class="empty-state">
        Chargement des détails de la recette...
    </div>
}
else
{
    <div class="page-title">
        <div>
            <h2>🍽️ @recipe.Title</h2>
            <p class="page-subtitle">
                Détails complets de la recette, informations nutritionnelles et ingrédients utilisés.
            </p>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-warning"
                    @onclick='() => Nav.NavigateTo($"/recipes/edit/{recipe.Id}")'>
                ✏️ Modifier
            </button>

            <button class="btn btn-secondary"
                    @onclick='() => Nav.NavigateTo("/recipes")'>
                ← Retour
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="detail-card">
                <div class="detail-card-header">
                    <div class="detail-icon">🍲</div>
                    <div>
                        <h4>@recipe.Title</h4>
                        <p>@recipe.Description</p>
                    </div>
                </div>

                <hr />

                <div class="recipe-info-grid">
                    <div class="info-box">
                        <span class="info-label">Catégorie</span>
                        <strong>@recipe.Category</strong>
                    </div>

                    <div class="info-box">
                        <span class="info-label">Cuisine</span>
                        <strong>@recipe.CuisineType</strong>
                    </div>

                    <div class="info-box">
                        <span class="info-label">Personnes</span>
                        <strong>👤 @recipe.Servings</strong>
                    </div>

                    <div class="info-box">
                        <span class="info-label">Préparation</span>
                        <strong>⏱️ @recipe.PrepTimeMinutes min</strong>
                    </div>

                    <div class="info-box">
                        <span class="info-label">Créée le</span>
                        <strong>📅 @recipe.CreatedAt.ToString("dd/MM/yyyy")</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="calorie-card">
                <div class="calorie-icon">🔥</div>

                <p class="calorie-label">Calories totales</p>
                <h2>@totalCalories.ToString("F0")</h2>
                <span>kcal</span>

                <hr />

                <p class="calorie-label">Calories par personne</p>
                <h3>@caloriesPerPerson.ToString("F0")</h3>
                <span>kcal / pers.</span>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="card-header">
            🥕 Ingrédients (@recipe.RecipeIngredients.Count)
        </div>

        @if (!recipe.RecipeIngredients.Any())
        {
            <div class="empty-state">
                Aucun ingrédient ajouté pour cette recette.
            </div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Ingrédient</th>
                        <th>Quantité</th>
                        <th>Unité</th>
                        <th>Calories</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ri in recipe.RecipeIngredients)
                    {
                        <tr>
                            <td>
                                <strong>@ri.Ingredient?.Name</strong>
                            </td>
                            <td>@ri.Quantity</td>
                            <td>@ri.Ingredient?.Unit</td>
                            <td>
                                <span class="text-danger fw-bold">
                                    @((ri.Quantity * (ri.Ingredient?.CaloriesPerUnit ?? 0)).ToString("F0")) kcal
                                </span>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(ri.Notes) ? "-" : ri.Notes)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Recipe? recipe;
    private float totalCalories;
    private float caloriesPerPerson;

    protected override async Task OnParametersSetAsync()
    {
        recipe = await RecipeService.GetByIdAsync(Id);

        if (recipe != null)
        {
            totalCalories = await RecipeService.GetTotalCaloriesAsync(Id);
            caloriesPerPerson = await RecipeService.GetCaloriesPerPersonAsync(Id);
        }
    }
}