@page "/recipes/create"
@page "/recipes/edit/{Id:int}"
@inject IRecipeService RecipeService
@inject IIngredientService IngredientService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="page-title">
    <div>
        <h2>@(Id == null ? "➕ Nouvelle recette" : "✏️ Modifier la recette")</h2>
        <p class="page-subtitle">
            @(Id == null ? "Créer une nouvelle recette avec ses ingrédients." : "Modifier les informations de la recette sélectionnée.")
        </p>
    </div>
</div>

<div class="form-card">
    <EditForm Model="model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <h5 class="form-section-title">Informations générales</h5>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Titre</label>
                <InputText class="form-control"
                           placeholder="Ex: Ojja tunisienne au poulet"
                           @bind-Value="model.Title" />
            </div>

            <div class="col-md-3 mb-3">
                <label class="form-label">Personnes</label>
                <InputNumber class="form-control"
                             @bind-Value="model.Servings" />
            </div>

            <div class="col-md-3 mb-3">
                <label class="form-label">Temps</label>
                <InputNumber class="form-control"
                             placeholder="Minutes"
                             @bind-Value="model.PrepTimeMinutes" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Catégorie</label>
                <InputSelect class="form-select custom-select"
                             @bind-Value="model.Category">
                    @foreach (var cat in Enum.GetValues<Category>())
                    {
                        <option value="@cat">@cat</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Type de cuisine</label>
                <InputSelect class="form-select custom-select"
                             @bind-Value="model.CuisineType">
                    @foreach (var ct in Enum.GetValues<CuisineType>())
                    {
                        <option value="@ct">@ct</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control"
                           placeholder="Décrire brièvement la recette..."
                           @bind-Value="model.Description"
                           rows="4" />
        </div>

        <h5 class="form-section-title">🥕 Ingrédients</h5>

        <div class="ingredient-add-box">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Ingrédient</label>
                    <select class="form-select custom-select" @bind="selectedIngredientId">
                        <option value="0">-- Choisir un ingrédient --</option>
                        @foreach (var ing in allIngredients)
                        {
                            <option value="@ing.Id">@ing.Name (@ing.Unit)</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Quantité</label>
                    <input type="number"
                           class="form-control"
                           placeholder="Quantité"
                           @bind="selectedQuantity"
                           min="0.01"
                           step="0.01" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Notes</label>
                    <input type="text"
                           class="form-control"
                           placeholder="Optionnel"
                           @bind="selectedNotes" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="button"
                            class="btn btn-outline-primary w-100"
                            @onclick="AddIngredient">
                        + Ajouter
                    </button>
                </div>
            </div>
        </div>

        @if (selectedIngredients.Any())
        {
            <div class="table-card mt-3">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Ingrédient</th>
                            <th>Quantité</th>
                            <th>Notes</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in selectedIngredients)
                        {
                            <tr>
                                <td>
                                    <strong>@item.IngredientName</strong>
                                </td>
                                <td>@item.Quantity @item.Unit</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                                <td class="text-end">
                                    <button type="button"
                                            class="btn btn-sm btn-danger"
                                            @onclick="() => RemoveIngredient(item.IngredientId)">
                                        🗑️ Supprimer
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state mt-3">
                Aucun ingrédient sélectionné pour cette recette.
            </div>
        }

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button class="btn btn-secondary"
                    type="button"
                    @onclick='() => Nav.NavigateTo("/recipes")'>
                Annuler
            </button>

            <button class="btn btn-primary" type="submit">
                💾 Enregistrer
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private Recipe model = new();
    private List<Ingredient> allIngredients = new();

    private List<IngredientLine> selectedIngredients = new();
    private int selectedIngredientId = 0;
    private float selectedQuantity = 1;
    private string selectedNotes = "";

    protected override async Task OnInitializedAsync()
    {
        allIngredients = await IngredientService.GetAllAsync();

        if (Id != null)
        {
            var existing = await RecipeService.GetByIdAsync(Id.Value);

            if (existing != null)
            {
                model = existing;

                selectedIngredients = existing.RecipeIngredients.Select(ri => new IngredientLine
                {
                    IngredientId = ri.IngredientId,
                    IngredientName = ri.Ingredient?.Name ?? "",
                    Unit = ri.Ingredient?.Unit ?? "",
                    Quantity = ri.Quantity,
                    Notes = ri.Notes
                }).ToList();
            }
        }
    }

    private void AddIngredient()
    {
        if (selectedIngredientId == 0 || selectedQuantity <= 0)
            return;

        if (selectedIngredients.Any(i => i.IngredientId == selectedIngredientId))
            return;

        var ing = allIngredients.First(i => i.Id == selectedIngredientId);

        selectedIngredients.Add(new IngredientLine
        {
            IngredientId = ing.Id,
            IngredientName = ing.Name,
            Unit = ing.Unit,
            Quantity = selectedQuantity,
            Notes = selectedNotes
        });

        selectedIngredientId = 0;
        selectedQuantity = 1;
        selectedNotes = "";
    }

    private void RemoveIngredient(int ingredientId)
    {
        selectedIngredients.RemoveAll(i => i.IngredientId == ingredientId);
    }

    private async Task SaveAsync()
    {
        if (Id == null)
        {
            var created = await RecipeService.CreateAsync(model);

            foreach (var item in selectedIngredients)
            {
                await RecipeService.AddIngredientAsync(
                    created.Id,
                    item.IngredientId,
                    item.Quantity,
                    item.Notes
                );
            }
        }
        else
        {
            await RecipeService.UpdateAsync(Id.Value, model);
        }

        Nav.NavigateTo("/recipes");
    }

    private class IngredientLine
    {
        public int IngredientId { get; set; }
        public string IngredientName { get; set; } = "";
        public string Unit { get; set; } = "";
        public float Quantity { get; set; }
        public string? Notes { get; set; }
    }
}