@page "/recipes/create"
@page "/recipes/edit/{Id:int}"
@inject IRecipeService RecipeService
@inject IIngredientService IngredientService
@inject NavigationManager Nav
@rendermode InteractiveServer

<h2>@(Id == null ? "➕ Nouvelle recette" : "✏️ Modifier la recette")</h2>

<EditForm Model="model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />
    <ValidationSummary class="alert alert-danger" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Titre</label>
            <InputText class="form-control" @bind-Value="model.Title" />
        </div>
        <div class="col-md-3 mb-3">
            <label>Personnes</label>
            <InputNumber class="form-control" @bind-Value="model.Servings" />
        </div>
        <div class="col-md-3 mb-3">
            <label>Temps (minutes)</label>
            <InputNumber class="form-control" @bind-Value="model.PrepTimeMinutes" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Catégorie</label>
            <InputSelect class="form-select" @bind-Value="model.Category">
                @foreach (var cat in Enum.GetValues<Category>())
                {
                    <option value="@cat">@cat</option>
                }
            </InputSelect>
        </div>
        <div class="col-md-6 mb-3">
            <label>Type de cuisine</label>
            <InputSelect class="form-select" @bind-Value="model.CuisineType">
                @foreach (var ct in Enum.GetValues<CuisineType>())
                {
                    <option value="@ct">@ct</option>
                }
            </InputSelect>
        </div>
    </div>

    <div class="mb-3">
        <label>Description</label>
        <InputTextArea class="form-control" @bind-Value="model.Description" rows="3" />
    </div>

    <!-- Sélection des ingrédients -->
    <h5 class="mt-4">🥕 Ingrédients</h5>
    <div class="row mb-2">
        <div class="col-md-5">
            <select class="form-select" @bind="selectedIngredientId">
                <option value="0">-- Choisir un ingrédient --</option>
                @foreach (var ing in allIngredients)
                {
                    <option value="@ing.Id">@ing.Name (@ing.Unit)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Quantité"
                   @bind="selectedQuantity" min="0.01" step="0.01" />
        </div>
        <div class="col-md-2">
            <input type="text" class="form-control" placeholder="Notes (optionnel)"
                   @bind="selectedNotes" />
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-primary w-100"
                    @onclick="AddIngredient">
                + Ajouter
            </button>
        </div>
    </div>

    @if (selectedIngredients.Any())
    {
        <table class="table table-sm table-bordered mt-2">
            <thead>
                <tr>
                    <th>Ingrédient</th>
                    <th>Quantité</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in selectedIngredients)
                {
                    <tr>
                        <td>@item.IngredientName</td>
                        <td>@item.Quantity @item.Unit</td>
                        <td>@item.Notes</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-danger"
                                    @onclick="() => RemoveIngredient(item.IngredientId)">
                                🗑️
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-4">
        <button class="btn btn-success" type="submit">💾 Enregistrer</button>
        <button class="btn btn-secondary ms-2" type="button"
                @onclick='() => Nav.NavigateTo("/recipes")'>
            Annuler
        </button>
    </div>
</EditForm>

@code {
    [Parameter] public int? Id { get; set; }

    private Recipe model = new();
    private List<Ingredient> allIngredients = new();

    // Ingrédients sélectionnés pour la recette
    private List<IngredientLine> selectedIngredients = new();
    private int selectedIngredientId = 0;
    private float selectedQuantity = 1;
    private string selectedNotes = "";

    protected override async Task OnInitializedAsync()
    {
        allIngredients = await IngredientService.GetAllAsync();

        if (Id != null)
        {
            var existing = await RecipeService.GetByIdAsync(Id.Value);
            if (existing != null)
            {
                model = existing;
                // Charger les ingrédients existants
                selectedIngredients = existing.RecipeIngredients.Select(ri => new IngredientLine
                {
                    IngredientId = ri.IngredientId,
                    IngredientName = ri.Ingredient?.Name ?? "",
                    Unit = ri.Ingredient?.Unit ?? "",
                    Quantity = ri.Quantity,
                    Notes = ri.Notes
                }).ToList();
            }
        }
    }

    private void AddIngredient()
    {
        if (selectedIngredientId == 0 || selectedQuantity <= 0) return;
        if (selectedIngredients.Any(i => i.IngredientId == selectedIngredientId)) return;

        var ing = allIngredients.First(i => i.Id == selectedIngredientId);
        selectedIngredients.Add(new IngredientLine
        {
            IngredientId = ing.Id,
            IngredientName = ing.Name,
            Unit = ing.Unit,
            Quantity = selectedQuantity,
            Notes = selectedNotes
        });

        selectedIngredientId = 0;
        selectedQuantity = 1;
        selectedNotes = "";
    }

    private void RemoveIngredient(int ingredientId)
    {
        selectedIngredients.RemoveAll(i => i.IngredientId == ingredientId);
    }

    private async Task SaveAsync()
    {
        if (Id == null)
        {
            var created = await RecipeService.CreateAsync(model);
            foreach (var item in selectedIngredients)
                await RecipeService.AddIngredientAsync(created.Id, item.IngredientId, item.Quantity, item.Notes);
        }
        else
        {
            await RecipeService.UpdateAsync(Id.Value, model);
        }

        Nav.NavigateTo("/recipes");
    }

    // Classe locale pour gérer les lignes d'ingrédients
    private class IngredientLine
    {
        public int IngredientId { get; set; }
        public string IngredientName { get; set; } = "";
        public string Unit { get; set; } = "";
        public float Quantity { get; set; }
        public string? Notes { get; set; }
    }
}