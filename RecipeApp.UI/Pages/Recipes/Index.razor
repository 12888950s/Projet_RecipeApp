@page "/recipes"
@inject IRecipeService RecipeService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="page-title">
    <div>
        <h2>🍽️ Recettes</h2>
        <p class="page-subtitle">
            Consultez, recherchez et gérez toutes les recettes enregistrées.
        </p>
    </div>

    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/recipes/create")'>
        + Ajouter une recette
    </button>
</div>

<div class="search-bar">
    <input class="form-control"
           placeholder="Rechercher une recette..."
           @bind="searchTerm"
           @bind:event="oninput"
           @onkeyup="OnSearch" />
</div>

@if (recipes == null)
{
    <div class="empty-state">
        Chargement des recettes...
    </div>
}
else if (!recipes.Any())
{
    <div class="empty-state">
        Aucune recette trouvée.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var recipe in recipes)
        {
            <div class="col-lg-4 col-md-6">
                <div class="recipe-card h-100">
                    <div class="recipe-card-body">
                        <div class="recipe-icon">🍲</div>

                        <h5 class="recipe-title">@recipe.Title</h5>

                        <p class="recipe-description">
                            @recipe.Description
                        </p>

                        <div class="recipe-badges">
                            <span class="badge recipe-badge-primary">@recipe.Category</span>
                            <span class="badge recipe-badge-secondary">@recipe.CuisineType</span>
                        </div>
                    </div>

                    <div class="recipe-card-footer">
                        <div class="recipe-meta">
                            <span>👤 @recipe.Servings pers.</span>
                            <span>⏱️ @recipe.PrepTimeMinutes min</span>
                        </div>

                        <div class="recipe-actions">
                            <button class="btn btn-sm btn-info"
                                    title="Voir détails"
                                    @onclick='() => Nav.NavigateTo($"/recipes/{recipe.Id}")'>
                                👁️
                            </button>

                            <button class="btn btn-sm btn-warning"
                                    title="Modifier"
                                    @onclick='() => Nav.NavigateTo($"/recipes/edit/{recipe.Id}")'>
                                ✏️
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    title="Supprimer"
                                    @onclick="() => DeleteAsync(recipe.Id)">
                                🗑️
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Recipe>? recipes;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        recipes = await RecipeService.GetAllAsync();
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            await LoadAsync();
        else
            recipes = await RecipeService.SearchAsync(searchTerm);
    }

    private async Task DeleteAsync(int id)
    {
        await RecipeService.DeleteAsync(id);
        await LoadAsync();
    }
}